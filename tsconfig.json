{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "./build",
    "declaration": false,
    "types": ["@openrct2/types"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "build"]
}
